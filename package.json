{
  "name": "react-aggregation",
  "version": "1.0.0",
  "description": "Pipelines de agregação para React",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "react-native": "src/index.ts",
  "scripts": {
    "postinstall": "is-ci || husky install",
    "clean": "rm -rf dist",
    "build": "yarn run clean && tsc -p ./tsconfig.json",
    "build:watch": "tsc --watch -p ./tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:performance": "jest tests/performance --testTimeout=30000",
    "test:ci": "jest --coverage --watchAll=false --ci",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:update-snapshots": "jest --updateSnapshot",
    "test:silent": "jest --silent",
    "test:verbose": "jest --verbose",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "version": "git add -A src",
    "postversion": "git push && git push --tags",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "publish:npm": "npm publish",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "prettier": "^3.2.5",
    "semantic-release": "^24.2.6",
    "ts-jest": "^29.4.0",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "sift": "^17.1.3"
  },
  "peerDependencies": {
    "typescript": ">=4.8.0"
  },
  "homepage": "https://github.com/raphaelsalviano/react-aggregation",
  "repository": {
    "type": "git",
    "url": "https://github.com/raphaelsalviano/react-aggregation.git"
  },
  "bugs": {
    "url": "https://github.com/raphaelsalviano/react-aggregation/issues"
  },
  "keywords": [
    "react",
    "aggregation",
    "mongodb",
    "pipeline",
    "database",
    "javascript",
    "typescript"
  ],
  "author": "Raphael Salviano <raphael_salviano@outlook.com>",
  "license": "MIT",
  "packageManager": "yarn@3.6.4",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
